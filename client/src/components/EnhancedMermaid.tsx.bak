import { useEffect, useRef, useState, useCallback, useMemo } from 'react';
import { createPortal } from 'react-dom';
import { 
  X, ZoomIn, ZoomOut, Maximize2, Move, Palette, 
  Maximize, Minimize2, CircleDot, Crosshair, RotateCcw,
  ChevronLeft, ChevronRight, Check
} from 'lucide-react';
import { useTheme } from '../context/ThemeContext';
import { mermaidThemeConfigs, type MermaidTheme } from './Mermaid';

// Granular zoom presets for quick selection
const ZOOM_PRESETS = [0.25, 0.5, 0.75, 1, 1.5, 2] as const;
const ZOOM_MIN = 0.1;
const ZOOM_MAX = 4;
const ZOOM_STEP = 0.05;

// Theme configuration with rich metadata and preview thumbnails
export interface ThemeOption {
  id: MermaidTheme;
  name: string;
  description: string;
  preview: {
    bg: string;
    primary: string;
    secondary: string;
    accent: string;
    text: string;
    border: string;
  };
  category: 'light' | 'dark' | 'special';
  shortcut: string;
}

// Extended theme definitions with previews
const THEME_OPTIONS: ThemeOption[] = [
  {
    id: 'default',
    name: 'Default',
    description: 'Classic blue diagram style',
    preview: { bg: '#ffffff', primary: '#326ce5', secondary: '#ececff', accent: '#9370db', text: '#333333', border: '#326ce5' },
    category: 'light',
    shortcut: '1',
  },
  {
    id: 'neutral',
    name: 'Neutral',
    description: 'Grayscale professional look',
    preview: { bg: '#ffffff', primary: '#999999', secondary: '#f4f4f4', accent: '#666666', text: '#333333', border: '#999999' },
    category: 'light',
    shortcut: '2',
  },
  {
    id: 'forest',
    name: 'Forest',
    description: 'Natural green palette',
    preview: { bg: '#ffffff', primary: '#13540c', secondary: '#cde498', accent: '#6eaa49', text: '#13540c', border: '#13540c' },
    category: 'light',
    shortcut: '3',
  },
  {
    id: 'base',
    name: 'Base',
    description: 'Warm cream tones',
    preview: { bg: '#ffffff', primary: '#f9a825', secondary: '#fff4dd', accent: '#f57c00', text: '#333333', border: '#f9a825' },
    category: 'light',
    shortcut: '4',
  },
  {
    id: 'dark',
    name: 'Dark',
    description: 'Dark mode with neon accents',
    preview: { bg: '#0a0a0a', primary: '#22c55e', secondary: '#1f2937', accent: '#3b82f6', text: '#ffffff', border: '#22c55e' },
    category: 'dark',
    shortcut: '5',
  },
];

const appThemeToMermaid: Record<string, MermaidTheme> = {
  'premium-dark': 'dark',
};

// Lazy-loaded mermaid instance - singleton pattern for lazy loading
let mermaid: any = null;

async function getMermaid() {
  if (!mermaid) {
    // Dynamic import - only loads when first diagram is rendered
    const m = await import('mermaid/dist/mermaid.esm.mjs');
    mermaid = m.default || m;
    // Initialize once on first load
    mermaid.initialize({ startOnLoad: false, theme: 'dark' });
  }
  return mermaid;
}

// Backward compatibility alias
const loadMermaid = getMermaid;

let currentMermaidTheme: MermaidTheme | null = null;

async function initMermaid(mermaidTheme: MermaidTheme, force = false) {
  if (currentMermaidTheme === mermaidTheme && !force) return;
  
  const mermaidModule = await loadMermaid();
  const isMobile = window.innerWidth < 640;
  const config = mermaidThemeConfigs[mermaidTheme];

  try {
    mermaidModule.initialize({
      startOnLoad: false,
      ...config,
      securityLevel: 'safe',
      fontFamily: 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
      fontSize: isMobile ? 12 : 14,
      flowchart: {
        useMaxWidth: false, // Allow natural width for better text rendering
        htmlLabels: true,
        curve: 'basis',
        nodeSpacing: isMobile ? 40 : 50,
        rankSpacing: isMobile ? 40 : 50,
        padding: isMobile ? 12 : 15,
        wrappingWidth: isMobile ? 150 : 200,
      },
      sequence: {
        diagramMarginX: isMobile ? 20 : 50,
        diagramMarginY: isMobile ? 10 : 20,
        boxMargin: isMobile ? 5 : 10,
        noteMargin: isMobile ? 5 : 10,
        messageMargin: isMobile ? 25 : 35,
        mirrorActors: false,
        useMaxWidth: false,
      },
    });
    currentMermaidTheme = mermaidTheme;
  } catch (e) {
    console.error('Mermaid init error:', e);
  }
}

interface EnhancedMermaidProps {
  chart: string;
  compact?: boolean;
  onRenderResult?: (success: boolean) => void;
}

// Validate if content is a valid Mermaid diagram
function isValidMermaidSyntax(chart: string): boolean {
  if (!chart || typeof chart !== 'string') return false;
  const trimmed = chart.trim();
  if (!trimmed || trimmed.length < 10) return false;
  
  // Must start with a valid Mermaid diagram type
  const validStarts = ['graph', 'flowchart', 'sequenceDiagram', 'classDiagram', 'stateDiagram', 'erDiagram', 'journey', 'gantt', 'pie', 'gitGraph', 'mindmap', 'timeline', 'quadrantChart', 'sankey', 'xychart', 'block'];
  const firstLine = trimmed.split('\n')[0].toLowerCase().trim();
  const hasValidStart = validStarts.some(start => firstLine.startsWith(start.toLowerCase()));
  if (!hasValidStart) return false;
  
  // Reject if it looks like code (YAML, JSON, etc.)
  const lowerContent = trimmed.toLowerCase();
  const codeIndicators = [
    'name:', 'hosts:', 'tasks:', 'become:', // YAML/Ansible
    '```', '~~~', // Markdown code blocks
    'import ', 'from ', 'export ', 'const ', 'let ', 'var ', 'function ', // JS/TS
    'def ', 'class ', 'if __name__', // Python
    '<?php', '<?xml', '<!DOCTYPE', // PHP/XML/HTML
    'package ', 'public class', 'private ', // Java
    '"$schema"', '"type":', // JSON Schema
  ];
  
  if (codeIndicators.some(indicator => lowerContent.includes(indicator))) {
    return false;
  }
  
  // Must have at least some diagram content (nodes/edges)
  const contentLines = trimmed.split('\n').filter(line => {
    const l = line.trim();
    return l && !l.startsWith('%%') && !validStarts.some(s => l.toLowerCase().startsWith(s.toLowerCase()));
  });
  
  if (contentLines.length < 2) return false;
  
  // Check for diagram-like patterns (arrows, brackets, etc.)
  const diagramPatterns = /-->|==>|-.->|--[>|]|->|<--|===|---|[\[\](){}]|participant|subgraph|style\s+\w+/i;
  const hasDiagramSyntax = contentLines.some(line => diagramPatterns.test(line));
  
  return hasDiagramSyntax;
}

export function EnhancedMermaid({ chart, compact = false, onRenderResult }: EnhancedMermaidProps) {
  const { theme: appTheme } = useTheme();
  const containerRef = useRef<HTMLDivElement>(null);
  const svgContainerRef = useRef<HTMLDivElement>(null);
  const [error, setError] = useState<string | null>(null);
  const [svgContent, setSvgContent] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [isExpanded, setIsExpanded] = useState(false);
  const [zoom, setZoom] = useState(1);
  const [position, setPosition] = useState({ x: 0, y: 0 });
  const [isDragging, setIsDragging] = useState(false);
  const [dragStart, setDragStart] = useState({ x: 0, y: 0 });
  const [selectedMermaidTheme, setSelectedMermaidTheme] = useState<MermaidTheme | null>(() => {
    const saved = localStorage.getItem('mermaid-theme');
    return saved ? (saved as MermaidTheme) : null;
  });
  const [showThemePicker, setShowThemePicker] = useState(false);
  const [showZoomMenu, setShowZoomMenu] = useState(false);
  const renderIdRef = useRef(0);
  
  // Ref for fit-to-screen calculation
  const contentRef = useRef<HTMLDivElement>(null);
  
  // Mobile pinch-to-zoom and pan state for inline view
  const [inlineZoom, setInlineZoom] = useState(1);
  const [inlinePan, setInlinePan] = useState({ x: 0, y: 0 });
  const [isPinching, setIsPinching] = useState(false);
  const inlineTouchRef = useRef({ dist: 0, initialZoom: 1, initialPan: { x: 0, y: 0 } });
  const dragStartRef = useRef({ x: 0, y: 0, startPan: { x: 0, y: 0 } });
  const lastTapRef = useRef<number>(0);
  
  // Detect mobile device - use 768px breakpoint for better tablet support
  const isMobileDevice = typeof window !== 'undefined' && window.innerWidth < 768;
  
  // Check if chart is valid
  const isValidChart = isValidMermaidSyntax(chart);

  // Persist theme selection to localStorage
  const handleThemeChange = useCallback((theme: MermaidTheme | null) => {
    setSelectedMermaidTheme(theme);
    if (theme) {
      localStorage.setItem('mermaid-theme', theme);
    } else {
      localStorage.removeItem('mermaid-theme');
    }
  }, []);

  const effectiveMermaidTheme = selectedMermaidTheme || appThemeToMermaid[appTheme] || 'forest';

  const resetView = useCallback(() => {
    setZoom(1);
    setPosition({ x: 0, y: 0 });
  }, []);

  // Snap to nearest preset for cleaner zoom levels
  const snapToPreset = useCallback((value: number): number => {
    const closest = ZOOM_PRESETS.reduce((prev, curr) => 
      Math.abs(curr - value) < Math.abs(prev - value) ? curr : prev
    );
    return Math.abs(closest - value) < 0.1 ? closest : value;
  }, []);

  // Zoom in to next preset
  const handleZoomIn = useCallback(() => {
    setZoom(prev => {
      const next = prev + 0.25;
      return Math.min(next, ZOOM_MAX);
    });
  }, []);

  // Zoom out to previous preset
  const handleZoomOut = useCallback(() => {
    setZoom(prev => {
      const next = prev - 0.25;
      return Math.max(next, ZOOM_MIN);
    });
  }, []);

  // Set exact zoom level from preset
  const handleZoomPreset = useCallback((preset: number) => {
    setZoom(preset);
    setShowZoomMenu(false);
  }, []);

  // Fit diagram to screen
  const handleFitToScreen = useCallback(() => {
    if (!svgContainerRef.current || !contentRef.current) return;
    
    const container = svgContainerRef.current;
    const content = contentRef.current.querySelector('.mermaid-container');
    if (!content) return;
    
    const containerRect = container.getBoundingClientRect();
    const contentRect = content.getBoundingClientRect();
    
    // Calculate scale to fit with padding
    const padding = 40;
    const scaleX = (containerRect.width - padding * 2) / contentRect.width;
    const scaleY = (containerRect.height - padding * 2) / contentRect.height;
    const fitScale = Math.min(scaleX, scaleY, 1); // Don't scale up beyond 100%
    
    setZoom(fitScale);
    setPosition({ x: 0, y: 0 });
    setShowZoomMenu(false);
  }, []);

  // Handle slider change with smooth transition
  const handleSliderChange = useCallback((e: React.ChangeEvent<HTMLInputElement>) => {
    const value = parseFloat(e.target.value);
    setZoom(value);
  }, []);

  // Clamp zoom value
  const clampZoom = useCallback((value: number): number => {
    return Math.max(ZOOM_MIN, Math.min(ZOOM_MAX, value));
  }, []);

  const handleMouseDown = useCallback((e: React.MouseEvent) => {
    if (!isExpanded) return;
    setIsDragging(true);
    setDragStart({ x: e.clientX - position.x, y: e.clientY - position.y });
  }, [isExpanded, position.x, position.y]);

  const handleMouseMove = useCallback((e: React.MouseEvent) => {
    if (!isDragging) return;
    setPosition({ x: e.clientX - dragStart.x, y: e.clientY - dragStart.y });
  }, [isDragging, dragStart.x, dragStart.y]);

  const handleMouseUp = useCallback(() => setIsDragging(false), []);

  const handleTouchStart = useCallback((e: React.TouchEvent) => {
    if (!isExpanded) return;
    if (e.touches.length === 1) {
      setIsDragging(true);
      setDragStart({ x: e.touches[0].clientX - position.x, y: e.touches[0].clientY - position.y });
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      inlineTouchRef.current = { dist, initialZoom: zoom, initialPan: { x: position.x, y: position.y } };
    }
  }, [isExpanded, position.x, position.y, zoom]);

  const handleTouchMove = useCallback((e: React.TouchEvent) => {
    if (!isExpanded) return;
    if (e.touches.length === 1 && isDragging) {
      setPosition({ x: e.touches[0].clientX - dragStart.x, y: e.touches[0].clientY - dragStart.y });
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(e.touches[0].clientX - e.touches[1].clientX, e.touches[0].clientY - e.touches[1].clientY);
      const scale = dist / inlineTouchRef.current.dist;
      setZoom(z => Math.max(ZOOM_MIN, Math.min(z * scale, ZOOM_MAX)));
      inlineTouchRef.current.dist = dist;
    }
  }, [isExpanded, isDragging, dragStart.x, dragStart.y]);

  const handleTouchEnd = useCallback(() => setIsDragging(false), []);

  // Wheel-based zoom handler with smooth transitions
  const handleWheel = useCallback((e: WheelEvent) => {
    if (!isExpanded) return;
    e.preventDefault();
    
    const delta = e.deltaY > 0 ? -0.1 : 0.1;
    const newZoom = clampZoom(zoom + delta);
    setZoom(newZoom);
  }, [isExpanded, zoom, clampZoom]);

  // Add wheel event listener
  useEffect(() => {
    const container = svgContainerRef.current;
    if (!container || !isExpanded) return;
    
    container.addEventListener('wheel', handleWheel, { passive: false });
    return () => container.removeEventListener('wheel', handleWheel);
  }, [isExpanded, handleWheel]);

  // All useEffect hooks must be called unconditionally
  useEffect(() => {
    if (isExpanded) {
      setZoom(1);
      setPosition({ x: 0, y: 0 });
    }
  }, [isExpanded]);

  useEffect(() => {
    if (!isExpanded) return;
    const handleKeyDown = (e: KeyboardEvent) => {
      // Skip if user is typing in an input
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
      
      const isMac = navigator.platform.toUpperCase().indexOf('MAC') >= 0;
      const ctrlOrCmd = isMac ? e.metaKey : e.ctrlKey;
      
      switch (e.key) {
        case 'Escape':
          e.stopPropagation();
          e.preventDefault();
          setIsExpanded(false);
          resetView();
          break;
        case 't':
        case 'T':
          if (!ctrlOrCmd) {
            e.preventDefault();
            setShowThemePicker(true);
          }
          break;
        case '+':
        case '=':
          if (ctrlOrCmd || e.shiftKey) {
            e.preventDefault();
            handleZoomIn();
          }
          break;
        case '-':
          if (ctrlOrCmd || e.shiftKey) {
            e.preventDefault();
            handleZoomOut();
          }
          break;
        case '0':
          if (ctrlOrCmd) {
            e.preventDefault();
            handleFitToScreen();
          } else if (!ctrlOrCmd) {
            e.preventDefault();
            setZoom(1);
            setPosition({ x: 0, y: 0 });
          }
          break;
        case '1':
          if (!ctrlOrCmd) {
            e.preventDefault();
            setZoom(1);
          }
          break;
        case 'ArrowLeft':
          if (e.altKey) {
            e.preventDefault();
            cycleTheme('prev');
          }
          break;
        case 'ArrowRight':
          if (e.altKey) {
            e.preventDefault();
            cycleTheme('next');
          }
          break;
      }
    };
    window.addEventListener('keydown', handleKeyDown, true);
    return () => window.removeEventListener('keydown', handleKeyDown, true);
  }, [isExpanded, resetView, handleZoomIn, handleZoomOut, handleFitToScreen, cycleTheme, handleThemeChange]);

  useEffect(() => {
    // Skip rendering if chart is invalid or on mobile
    if (!isValidChart || isMobileDevice) {
      setIsLoading(false);
      return;
    }
    
    if (!chart) {
      setError('Empty diagram');
      setIsLoading(false);
      return;
    }

    const currentRenderId = ++renderIdRef.current;
    setError(null);
    setSvgContent(null);
    setIsLoading(true);
    initMermaid(effectiveMermaidTheme, true);

    const id = `mermaid-${currentRenderId}-${Math.random().toString(36).slice(2, 11)}`;
    const cleanChart = chart.trim().replace(/\r\n/g, '\n').replace(/^\n+/, '').replace(/\n+$/, '');
    
    if (!cleanChart) {
      setError('Empty diagram');
      setIsLoading(false);
      return;
    }

    let cancelled = false;
    const renderChart = async () => {
      try {
        await new Promise(resolve => setTimeout(resolve, 50));
        if (cancelled) return;
        const mermaidModule = await loadMermaid();
        const { svg } = await mermaidModule.render(id, cleanChart);
        if (!cancelled && currentRenderId === renderIdRef.current) {
          setSvgContent(svg);
          setError(null);
        }
      } catch (err: any) {
        console.error('Mermaid render error:', err);
        if (!cancelled && currentRenderId === renderIdRef.current) {
          // Use enhanced error parsing for user-friendly messages
          const parsedError = parseMermaidError(err);
          setError(parsedError.message);
        }
      } finally {
        if (!cancelled && currentRenderId === renderIdRef.current) {
          setIsLoading(false);
        }
      }
    };

    renderChart();
    return () => { cancelled = true; };
  }, [chart, effectiveMermaidTheme, isValidChart, isMobileDevice]);

  // Inline touch handlers - pinch-to-zoom and swipe panning
  const handleInlineTouchStart = useCallback((e: React.TouchEvent) => {
    const touches = e.touches;
    
    if (touches.length === 1) {
      // Single touch - start swipe/pan
      dragStartRef.current = {
        x: touches[0].clientX,
        y: touches[0].clientY,
        startPan: { ...inlinePan },
      };
    } else if (touches.length === 2) {
      // Two fingers - start pinch-to-zoom
      setIsPinching(true);
      const dist = Math.hypot(
        touches[0].clientX - touches[1].clientX,
        touches[0].clientY - touches[1].clientY
      );
      inlineTouchRef.current = { 
        dist, 
        initialZoom: inlineZoom,
        initialPan: { ...inlinePan },
      };
    }
  }, [inlineZoom, inlinePan]);
  
  const handleInlineTouchMove = useCallback((e: React.TouchEvent) => {
    const touches = e.touches;
    
    if (touches.length === 2 && isPinching) {
      e.preventDefault();
      e.stopPropagation();
      const dist = Math.hypot(
        touches[0].clientX - touches[1].clientX,
        touches[0].clientY - touches[1].clientY
      );
      const scale = dist / inlineTouchRef.current.dist;
      const newZoom = Math.max(0.5, Math.min(inlineTouchRef.current.initialZoom * scale, 3));
      setInlineZoom(newZoom);
      
      // Pan while pinching for better UX
      const centerX = (touches[0].clientX + touches[1].clientX) / 2;
      const centerY = (touches[0].clientY + touches[1].clientY) / 2;
      const deltaX = (centerX - dragStartRef.current.x) * 0.3;
      const deltaY = (centerY - dragStartRef.current.y) * 0.3;
      setInlinePan({
        x: inlineTouchRef.current.initialPan.x + deltaX,
        y: inlineTouchRef.current.initialPan.y + deltaY,
      });
    } else if (touches.length === 1 && !isPinching) {
      // Single finger swipe/pan
      const deltaX = touches[0].clientX - dragStartRef.current.x;
      const deltaY = touches[0].clientY - dragStartRef.current.y;
      setInlinePan({
        x: dragStartRef.current.startPan.x + deltaX,
        y: dragStartRef.current.startPan.y + deltaY,
      });
    }
  }, [isPinching]);
  
  const handleInlineTouchEnd = useCallback((e: React.TouchEvent) => {
    const now = Date.now();
    const timeSinceLastTap = now - lastTapRef.current;
    
    // Double-tap to expand on mobile
    if (e.touches.length === 0 && timeSinceLastTap < 300 && !isPinching && !compact) {
      setIsExpanded(true);
    }
    
    lastTapRef.current = now;
    setIsPinching(false);
  }, [isPinching, compact]);
  
  const handleInlineDoubleTap = useCallback(() => {
    // Toggle between 1x and 1.5x zoom on double tap
    setInlineZoom(prev => prev === 1 ? 1.5 : 1);
  }, []);

  // Old mermaidThemes - kept for compatibility but THEME_OPTIONS is preferred
  const mermaidThemes: { id: MermaidTheme; name: string; color: string }[] = [
    { id: 'default', name: 'Default', color: '#326ce5' },
    { id: 'neutral', name: 'Neutral', color: '#999' },
    { id: 'dark', name: 'Dark', color: '#22c55e' },
    { id: 'forest', name: 'Forest', color: '#6eaa49' },
    { id: 'base', name: 'Base', color: '#f9a825' },
  ];

  // Cycle to next/previous theme
  const cycleTheme = useCallback((direction: 'next' | 'prev') => {
    const effectiveThemeId = selectedMermaidTheme || 'forest';
    const currentIndex = THEME_OPTIONS.findIndex(t => t.id === effectiveThemeId);
    let newIndex: number;
    
    if (currentIndex === -1) {
      newIndex = direction === 'next' ? 0 : THEME_OPTIONS.length - 1;
    } else {
      newIndex = direction === 'next' 
        ? (currentIndex + 1) % THEME_OPTIONS.length 
        : (currentIndex - 1 + THEME_OPTIONS.length) % THEME_OPTIONS.length;
    }
    
    const newTheme = THEME_OPTIONS[newIndex].id;
    setSelectedMermaidTheme(newTheme);
    localStorage.setItem('mermaid-theme', newTheme);
  }, [selectedMermaidTheme]);

  // Now we can have early returns after all hooks are called
  
  // Validate chart content before rendering
  if (!isValidChart) {
    console.warn('EnhancedMermaid: Invalid or non-Mermaid content detected, skipping render');
    onRenderResult?.(false);
    return null;
  }
  
  // On mobile, just return null - diagrams don't render well on small screens
  if (isMobileDevice) {
    onRenderResult?.(false);
    return null;
  }

  // Silently hide failed diagrams - don't show error to user
  if (error) {
    console.warn('EnhancedMermaid diagram skipped due to error:', error);
    onRenderResult?.(false);
    return null;
  }

  if (isLoading) {
    return (
      <div className="w-full flex justify-center items-center py-12">
        <div className="flex flex-col items-center gap-2">
          <div className="w-8 h-8 border-2 border-primary/30 border-t-primary rounded-full animate-spin" />
          <div className="text-xs text-white/30">Rendering diagram...</div>
        </div>
      </div>
    );
  }

  if (!svgContent) {
    onRenderResult?.(false);
    return null;
  }
  
  // Check if SVG content is actually valid (not empty or too small)
  if (svgContent.length < 100 || !svgContent.includes('<svg')) {
    console.warn('EnhancedMermaid: SVG content appears invalid or empty');
    onRenderResult?.(false);
    return null;
  }
  
  // Successfully rendered
  onRenderResult?.(true);
  
  const isMobile = typeof window !== 'undefined' && window.innerWidth < 640;

  if (isExpanded) {
    return createPortal(
      <div className="fixed inset-0 z-[9999] bg-black flex flex-col">
        {/* Enhanced header with zoom controls */}
        <div className="flex items-center justify-between px-3 py-2 border-b border-white/10 bg-black/90 shrink-0">
          <div className="flex items-center gap-2 text-[10px] text-white/50 uppercase tracking-widest">
            <Move className="w-3.5 h-3.5" />
            <span>Zoom: {Math.round(zoom * 100)}%</span>
          </div>
          
          <div className="flex items-center gap-1">
            {/* Theme picker with enhanced dropdown */}
            <div className="relative">
              <button 
                onClick={() => { setShowThemePicker(!showThemePicker); setShowZoomMenu(false); }} 
                className={`p-2 rounded transition-colors flex items-center gap-1.5 ${
                  showThemePicker 
                    ? 'bg-primary/20 text-primary' 
                    : 'hover:bg-white/10 text-white/70'
                }`}
                title="Theme (T) - Press number keys 1-5 for quick select"
                aria-label="Change diagram theme"
                aria-expanded={showThemePicker}
              >
                <Palette className="w-4 h-4" />
                <span className="text-[9px] hidden sm:inline font-medium">{effectiveMermaidTheme}</span>
              </button>
              
              {showThemePicker && (
                <div className="absolute top-full right-0 mt-2 w-72 bg-black/95 backdrop-blur-xl border border-white/20 rounded-xl shadow-2xl shadow-black/50 overflow-hidden z-50">
                  {/* Header */}
                  <div className="px-4 py-3 border-b border-white/10 flex items-center justify-between bg-white/5">
                    <div className="flex items-center gap-2">
                      <Palette className="w-4 h-4 text-white/60" />
                      <span className="text-xs font-medium text-white/90">Theme</span>
                    </div>
                    <div className="flex items-center gap-1">
                      <button
                        onClick={(e) => { e.stopPropagation(); cycleTheme('prev'); }}
                        className="p-1 hover:bg-white/10 rounded transition-colors"
                        title="Previous theme (Left Arrow)"
                      >
                        <ChevronLeft className="w-4 h-4 text-white/60" />
                      </button>
                      <button
                        onClick={(e) => { e.stopPropagation(); cycleTheme('next'); }}
                        className="p-1 hover:bg-white/10 rounded transition-colors"
                        title="Next theme (Right Arrow)"
                      >
                        <ChevronRight className="w-4 h-4 text-white/60" />
                      </button>
                    </div>
                  </div>

                  {/* Theme list with preview thumbnails */}
                  <div className="max-h-64 overflow-y-auto p-2 space-y-1">
                    {THEME_OPTIONS.map((theme) => {
                      const isSelected = effectiveMermaidTheme === theme.id;
                      return (
                        <button
                          key={theme.id}
                          onClick={() => { handleThemeChange(theme.id); setShowThemePicker(false); }}
                          className={`relative flex items-center gap-3 w-full px-3 py-2.5 text-left transition-all duration-150 rounded-lg ${
                            isSelected 
                              ? 'bg-primary/10 border border-primary/30' 
                              : 'hover:bg-white/5 border border-transparent'
                          }`}
                          title={theme.description}
                        >
                          {/* Mini preview canvas */}
                          <div 
                            className="w-10 h-10 rounded border-2 flex-shrink-0 flex items-center justify-center overflow-hidden"
                            style={{ 
                              backgroundColor: theme.preview.bg,
                              borderColor: theme.preview.border,
                            }}
                          >
                            <svg viewBox="0 0 40 40" className="w-full h-full">
                              <rect x="4" y="12" width="12" height="8" rx="2" fill={theme.preview.primary} />
                              <rect x="24" y="12" width="12" height="8" rx="2" fill={theme.preview.secondary} stroke={theme.preview.border} />
                              <path d="M16 16 L24 16" stroke={theme.preview.accent} strokeWidth="2" />
                            </svg>
                          </div>
                          
                          {/* Theme info */}
                          <div className="flex-1 min-w-0">
                            <div className={`text-xs font-medium ${isSelected ? 'text-primary' : 'text-white/90'}`}>
                              {theme.name}
                            </div>
                            <div className="text-[10px] text-white/40 truncate">
                              {theme.description}
                            </div>
                          </div>
                          
                          {/* Shortcut hint */}
                          <div className="flex-shrink-0">
                            <kbd className="px-1.5 py-0.5 text-[9px] bg-white/10 text-white/40 rounded border border-white/20 font-mono">
                              {theme.shortcut}
                            </kbd>
                          </div>
                          
                          {/* Selected indicator */}
                          {isSelected && (
                            <div className="absolute right-2 top-1/2 -translate-y-1/2">
                              <Check className="w-3.5 h-3.5 text-primary" />
                            </div>
                          )}
                        </button>
                      );
                    })}
                  </div>

                  {/* Footer with keyboard hint */}
                  <div className="px-4 py-2.5 border-t border-white/10 bg-white/5 flex items-center justify-between">
                    <div className="flex items-center gap-3 text-[10px] text-white/40">
                      <span className="flex items-center gap-1">
                        <kbd className="px-1 py-0.5 bg-white/10 rounded border border-white/20 font-mono">←</kbd>
                        <kbd className="px-1 py-0.5 bg-white/10 rounded border border-white/20 font-mono">→</kbd>
                        <span>cycle</span>
                      </span>
                      <span className="text-white/20">|</span>
                      <span className="flex items-center gap-1">
                        <kbd className="px-1 py-0.5 bg-white/10 rounded border border-white/20 font-mono">1</kbd>
                        <span>- </span>
                        <kbd className="px-1 py-0.5 bg-white/10 rounded border border-white/20 font-mono">5</kbd>
                        <span>select</span>
                      </span>
                    </div>
                    <button
                      onClick={() => { handleThemeChange(null); setShowThemePicker(false); }}
                      className={`text-[10px] px-2 py-1 rounded transition-colors ${
                        !selectedMermaidTheme 
                          ? 'bg-primary/20 text-primary' 
                          : 'text-white/50 hover:text-white hover:bg-white/10'
                      }`}
                    >
                      Auto
                    </button>
                  </div>
                </div>
              )}
            </div>
            
            <div className="w-px h-4 bg-white/20 mx-1" />
            
            {/* Zoom out button */}
            <button 
              onClick={handleZoomOut} 
              aria-label="Zoom out (25%)" 
              className="p-2 hover:bg-white/10 rounded transition-colors"
              title="Zoom out 25%"
            >
              <ZoomOut className="w-4 h-4 text-white/70" />
            </button>
            
            {/* Zoom presets dropdown */}
            <div className="relative">
              <button 
                onClick={() => { setShowZoomMenu(!showZoomMenu); setShowThemePicker(false); }}
                className="px-2 py-1 text-[10px] text-white/70 hover:text-white hover:bg-white/10 rounded transition-colors flex items-center gap-1 min-w-[52px] justify-center"
                title="Zoom presets"
                aria-label="Select zoom level"
              >
                <CircleDot className="w-3 h-3" />
                <span>{Math.round(zoom * 100)}%</span>
              </button>
              {showZoomMenu && (
                <div className="absolute top-full right-0 mt-1 bg-black border border-white/20 rounded shadow-lg z-20 min-w-[100px]">
                  {ZOOM_PRESETS.map((preset) => (
                    <button 
                      key={preset} 
                      onClick={() => handleZoomPreset(preset)}
                      className={`w-full px-3 py-1.5 text-left text-[11px] hover:bg-white/10 flex items-center justify-between gap-3 ${Math.abs(zoom - preset) < 0.01 ? 'text-primary bg-white/5' : 'text-white/70'}`}
                    >
                      <span>{Math.round(preset * 100)}%</span>
                      {Math.abs(zoom - preset) < 0.01 && <Crosshair className="w-3 h-3" />}
                    </button>
                  ))}
                </div>
              )}
            </div>
            
            {/* Zoom in button */}
            <button 
              onClick={handleZoomIn} 
              aria-label="Zoom in (25%)" 
              className="p-2 hover:bg-white/10 rounded transition-colors"
              title="Zoom in 25%"
            >
              <ZoomIn className="w-4 h-4 text-white/70" />
            </button>
            
            <div className="w-px h-4 bg-white/20 mx-1" />
            
            {/* Zoom slider */}
            <div className="hidden sm:flex items-center gap-2 px-2">
              <input
                type="range"
                min={ZOOM_MIN}
                max={ZOOM_MAX}
                step={ZOOM_STEP}
                value={zoom}
                onChange={handleSliderChange}
                className="w-24 h-1 bg-white/20 rounded-full appearance-none cursor-pointer [&::-webkit-slider-thumb]:appearance-none [&::-webkit-slider-thumb]:w-3 [&::-webkit-slider-thumb]:h-3 [&::-webkit-slider-thumb]:rounded-full [&::-webkit-slider-thumb]:bg-primary [&::-webkit-slider-thumb]:cursor-pointer [&::-webkit-slider-thumb]:transition-transform [&::-webkit-slider-thumb]:hover:scale-125"
                aria-label="Zoom slider"
                title={`Zoom: ${Math.round(zoom * 100)}%`}
              />
            </div>
            
            {/* Fit to screen button */}
            <button 
              onClick={handleFitToScreen} 
              aria-label="Fit to screen" 
              className="p-2 hover:bg-white/10 rounded transition-colors"
              title="Fit diagram to screen"
            >
              <Maximize className="w-4 h-4 text-white/70" />
            </button>
            
            {/* Reset view button */}
            <button 
              onClick={resetView} 
              className="p-2 hover:bg-white/10 rounded transition-colors"
              title="Reset zoom and position"
              aria-label="Reset view"
            >
              <RotateCcw className="w-4 h-4 text-white/70" />
            </button>
            
            <div className="w-px h-4 bg-white/20 mx-1" />
            
            {/* Close button */}
            <button 
              onClick={() => { setIsExpanded(false); resetView(); }} 
              className="p-2 hover:bg-white/10 rounded transition-colors" 
              title="Close (ESC)"
              aria-label="Close diagram viewer"
            >
              <X className="w-4 h-4 text-white/70" />
            </button>
          </div>
        </div>

        {/* Zoom info bar */}
        <div className="flex items-center justify-center px-4 py-1 bg-black/60 border-b border-white/5 text-[9px] text-white/40">
          <span>Presets: {ZOOM_PRESETS.map(p => `${p * 100}%`).join(' • ')}</span>
        </div>

        <div 
          ref={svgContainerRef}
          className="flex-1 overflow-hidden flex items-center justify-center"
          style={{ cursor: isDragging ? 'grabbing' : 'grab', userSelect: 'none', backgroundColor: '#0a0a0a' }}
          onMouseDown={handleMouseDown}
          onMouseMove={handleMouseMove}
          onMouseUp={handleMouseUp}
          onMouseLeave={handleMouseUp}
          onTouchStart={handleTouchStart}
          onTouchMove={handleTouchMove}
          onTouchEnd={handleTouchEnd}
          onClick={() => { setShowThemePicker(false); setShowZoomMenu(false); }}
        >
          <div 
            ref={contentRef}
            style={{ transform: `translate(${position.x}px, ${position.y}px) scale(${zoom})`, transformOrigin: 'center center', transition: isDragging ? 'none' : 'transform 0.15s cubic-bezier(0.4, 0, 0.2, 1)' }}
          >
            <div className="mermaid-container" dangerouslySetInnerHTML={{ __html: typeof DOMPurify !== 'undefined' ? DOMPurify.sanitize(svgContent, { USE_PROFILES: { svg: true } }) : svgContent }} />
          </div>
        </div>

        {/* Help footer */}
        <div className="absolute bottom-4 left-1/2 -translate-x-1/2 px-4 py-2 bg-black/80 border border-white/20 rounded-lg text-[10px] text-white/50 flex items-center gap-4">
          <span className="flex items-center gap-1.5">
            <Move className="w-3 h-3" />
            Drag to pan
          </span>
          <span className="text-white/20">•</span>
          <span className="flex items-center gap-1.5">
            <Maximize2 className="w-3 h-3" />
            Pinch/scroll to zoom
          </span>
          <span className="text-white/20">•</span>
          <span className="flex items-center gap-1.5">
            <X className="w-3 h-3" />
            ESC to close
          </span>
        </div>
      </div>,
      document.body
    );
  }

  return (
    <div ref={containerRef} className="relative group">
      <div 
        className={`w-full overflow-x-auto overflow-y-hidden rounded-lg border border-white/10 bg-black/20 ${compact ? 'p-2' : 'p-3 sm:p-4'} ${!compact ? 'cursor-pointer hover:border-primary/50 transition-colors' : ''}`}
        onClick={() => !compact && !isMobile && setIsExpanded(true)}
        onTouchStart={handleInlineTouchStart}
        onTouchMove={handleInlineTouchMove}
        onTouchEnd={handleInlineTouchEnd}
        onDoubleClick={handleInlineDoubleTap}
        style={{ touchAction: isPinching ? 'none' : 'pan-x pan-y' }}
      >
        <div 
          className="mermaid-container transition-transform duration-150 inline-block min-w-full" 
          style={{ 
            transform: `scale(${inlineZoom})`, 
            transformOrigin: 'top left',
          }}
          dangerouslySetInnerHTML={{ __html: typeof DOMPurify !== 'undefined' ? DOMPurify.sanitize(svgContent, { USE_PROFILES: { svg: true } }) : svgContent }} 
        />
      </div>
      
      {/* Zoom controls on mobile - compact inline zoom */}
      {isMobile && !compact && (
        <div className="absolute top-2 left-2 flex items-center gap-1 bg-black/80 rounded-lg border border-white/20 p-1">
          <button 
            onClick={(e) => { e.stopPropagation(); setInlineZoom(z => Math.max(ZOOM_MIN, z - 0.25)); }}
            className="p-1.5 text-white/70 hover:text-white hover:bg-white/10 rounded transition-colors"
            aria-label="Zoom out"
            title="Zoom out 25%"
          >
            <ZoomOut className="w-3.5 h-3.5" />
          </button>
          <button
            onClick={(e) => { e.stopPropagation(); setInlineZoom(1); }}
            className="px-2 py-1 text-[10px] text-white/70 hover:text-white hover:bg-white/10 rounded transition-colors min-w-[44px]"
            title="Reset to 100%"
          >
            {Math.round(inlineZoom * 100)}%
          </button>
          <button 
            onClick={(e) => { e.stopPropagation(); setInlineZoom(z => Math.min(ZOOM_MAX, z + 0.25)); }}
            className="p-1.5 text-white/70 hover:text-white hover:bg-white/10 rounded transition-colors"
            aria-label="Zoom in"
            title="Zoom in 25%"
          >
            <ZoomIn className="w-3.5 h-3.5" />
          </button>
        </div>
      )}
      
      {/* Expand button - always visible on mobile, hover on desktop */}
      {!compact && (
        <button 
          onClick={(e) => { e.stopPropagation(); setIsExpanded(true); }}
          className={`absolute top-2 right-2 p-2 bg-black/80 hover:bg-primary/90 rounded border border-white/20 transition-all ${isMobile ? 'opacity-80' : 'opacity-0 group-hover:opacity-100'}`}
          title="Expand diagram (full screen)"
          aria-label="Expand diagram"
        >
          <Maximize2 className="w-3.5 h-3.5 text-white" />
        </button>
      )}
      
      {/* Reset zoom button when zoomed - mobile only */}
      {isMobile && !compact && inlineZoom !== 1 && (
        <button 
          onClick={(e) => { e.stopPropagation(); setInlineZoom(1); }}
          className="absolute bottom-2 right-2 px-2 py-1 bg-black/80 rounded border border-white/20 text-[9px] text-white/70 hover:text-white flex items-center gap-1"
          title="Reset zoom"
        >
          <RotateCcw className="w-2.5 h-2.5" />
          Reset
        </button>
      )}
    </div>
  );
}
