  /* Mobile-optimized container utility */
  .container-mobile {
    @apply w-full px-4 mx-auto;
    max-width: 100%;
  }
  @media (min-width: 480px) {
    .container-mobile {
      @apply px-5;
    }
  }
  @media (min-width: 640px) {
    .container-mobile {
      @apply px-6;
    }
  }
  @media (min-width: 768px) {
    .container-mobile {
      @apply px-8;
    }
  }
  @media (min-width: 1024px) {
    .container-mobile {
      @apply px-10;
    }
  }

  /* Vertical rhythm utilities for mobile */
  .rhythm-mobile {
    @apply space-y-4;
  }
  @media (min-width: 480px) {
    .rhythm-mobile {
      @apply space-y-5;
    }
  }
  @media (min-width: 640px) {
    .rhythm-mobile {
      @apply space-y-6;
    }
  }
  @media (min-width: 768px) {
    .rhythm-mobile {
      @apply space-y-7;
    }
  }
  @media (min-width: 1024px) {
    .rhythm-mobile {
      @apply space-y-8;
    }
  }

  /* Mobile text optimization */
  .text-mobile-optimized {
    @apply text-base leading-relaxed;
    @apply antialiased;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Optimize line length for mobile reading */
    max-width: 32ch;
  }
  @media (min-width: 480px) {
    .text-mobile-optimized {
      max-width: 36ch;
    }
  }
  @media (min-width: 640px) {
    .text-mobile-optimized {
      max-width: 40ch;
    }
  }
  @media (min-width: 768px) {
    .text-mobile-optimized {
      max-width: 45ch;
    }
  }

  /* Mobile card utilities */
  .card-mobile {
    @apply bg-card rounded-xl border border-border p-4;
    @apply shadow-sm hover:shadow-md transition-shadow;
  }
  @media (min-width: 640px) {
    .card-mobile {
      @apply p-6;
    }
  }
  @media (min-width: 768px) {
    .card-mobile {
      @apply p-8;
    }
  }

  /* Mobile input utilities */
  .input-mobile {
    @apply w-full h-12 px-4 py-3 text-base rounded-lg border border-border;
    @apply bg-background text-foreground placeholder:text-muted-foreground;
    @apply focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2;
    @apply min-h-[44px];
  }

  /* Mobile safe area utilities */
  .safe-area-inset-bottom {
    padding-bottom: env(safe-area-inset-bottom);
  }
  .safe-area-inset-top {
    padding-top: env(safe-area-inset-top);
  }
  .safe-area-inset-left {
    padding-left: env(safe-area-inset-left);
  }
  .safe-area-inset-right {
    padding-right: env(safe-area-inset-right);
  }

  /* Mobile touch feedback */
  .touch-feedback {
    @apply active:bg-primary/10 active:scale-95;
    @apply transition-all duration-150;
  }

  /* Input touch feedback */
  .input-touch-feedback {
    @apply active:bg-primary/5;
    @apply transition-all duration-150;
  }

  /* Mobile visibility utilities */
  .hidden-mobile {
    @apply block;
  }
  @media (max-width: 767px) {
    .hidden-mobile {
      @apply hidden;
    }
  }
  .visible-mobile-only {
    @apply hidden;
  }
  @media (max-width: 767px) {
    .visible-mobile-only {
      @apply block;
    }
  }

  /* Container query utilities */
  .container-query {
    container-type: inline-size;
    container-name: card;
  }

  .container-sm {
    container-type: inline-size;
    container-name: container-sm;
  }

  .container-md {
    container-type: inline-size;
    container-name: container-md;
  }

  /* Container query responsive classes */
  @container (min-width: 640px) {
    .cq-sm\:flex-row {
      @apply flex-row;
    }
    .cq-sm\:grid-cols-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @container (min-width: 768px) {
    .cq-md\:flex-row {
      @apply flex-row;
    }
    .cq-md\:grid-cols-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @container (min-width: 1024px) {
    .cq-lg\:grid-cols-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  /* Mobile touch optimization */
  .touch-optimized {
    @apply touch-manipulation;
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
  }

  /* Mobile text optimization */
  .text-mobile-optimized {
    @apply text-base leading-relaxed;
    @apply antialiased;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Mobile card touch feedback */
  .card-touch {
    @apply relative overflow-hidden;
    @apply before:absolute before:inset-0 before:bg-primary/0 before:transition-colors before:duration-150;
    @apply active:before:bg-primary/5;
  }

  /* Mobile scroll snap */
  .scroll-snap-x {
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .scroll-snap-x > * {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  /* Mobile safe area padding utilities */
  .safe-area-pad-y {
    padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
  }

  .safe-area-pad-x {
    padding-left: env(safe-area-inset-left);
    padding-right: env(safe-area-inset-right);
  }

  /* Mobile bottom safe area */
  .pb-safe {
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }

  .pt-safe {
    padding-top: env(safe-area-inset-top, 0px);
  }

  .pl-safe {
    padding-left: env(safe-area-inset-left, 0px);
  }

  .pr-safe {
    padding-right: env(safe-area-inset-right, 0px);
  }

  /* Mobile navigation active indicator */
  .nav-indicator {
    @apply absolute bottom-1 left-1/2 -translate-x-1/2;
    @apply w-6 h-0.5 rounded-full bg-primary;
    @apply transition-all duration-200;
  }

  /* Mobile card stack */
  .card-stack {
    @apply relative;
  }

  .card-stack > * + * {
    @apply -mt-4;
  }

  /* Mobile grid card layout */
  .grid-cards {
    @apply grid gap-4;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }

  @media (min-width: 768px) {
    .grid-cards {
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }
  }

  /* Elevated layers with depth */
  .layer-1 {
    transform: var(--depth-layer-1);
  }
  .layer-2 {
    transform: var(--depth-layer-2);
  }
  .layer-3 {
    transform: var(--depth-layer-3);
  }

  /* Luminous edge lighting (for active/focused states) */
  .luminous {
    box-shadow:
      0 0 0 1px var(--luminous-edge),
      0 0 8px 2px var(--luminous-edge);
  }

  /* Floating card with parallax */
  .floating-card {
    @apply bg-glass-bg backdrop-blur-lg border-glass-border;
    box-shadow: var(--glass-shadow);
    transform: var(--depth-layer-2);
    transition:
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .floating-card:hover {
    @apply bg-glass-bg-hover border-glass-border-hover;
    transform: translateY(-4px) var(--depth-layer-3);
    box-shadow: var(--glass-shadow-hover);
  }

  /* Subtle ambient shadow for depth perception */
  .ambient-shadow {
    box-shadow: inset 0 0 20px -5px hsl(var(--background) / 0.1);
  }

  /* Focus ring with glass effect */
  .focus-glass {
    @apply focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring/50 focus-visible:ring-offset-2;
  }

  /* Apple Vision Pro gradient background */
  .bg-apple-gradient {
    background: var(--bg-gradient);
  }

  /* ============================================================================
     Apple Vision Pro Spatial Layout Utilities
     ============================================================================ */

  /* Vision Pro spatial container */
  .vision-spatial-container {
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  /* Vision Pro depth layers */
  .vision-depth-1 {
    transform: translateZ(0px);
  }

  .vision-depth-2 {
    transform: translateZ(8px);
  }

  .vision-depth-3 {
    transform: translateZ(16px);
  }

  .vision-depth-4 {
    transform: translateZ(24px);
  }

  /* Vision Pro floating elements */
  .vision-float {
    transform: translateZ(12px);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .vision-float:hover {
    transform: translateZ(24px) translateY(-8px);
  }

  /* Vision Pro card layouts */
  .vision-card-grid {
    @apply grid gap-6;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    perspective: 1200px;
    transform-style: preserve-3d;
  }

  @media (min-width: 768px) {
    .vision-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .vision-card-grid {
      grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
    }
  }

  /* Vision Pro spatial spacing */
  .vision-space-xs {
    gap: 8px;
  }

  .vision-space-sm {
    gap: 16px;
  }

  .vision-space-md {
    gap: 24px;
  }

  .vision-space-lg {
    gap: 32px;
  }

  .vision-space-xl {
    gap: 48px;
  }

  /* Vision Pro padding for spatial viewing */
  .vision-padding-sm {
    padding: 24px;
  }

  .vision-padding-md {
    padding: 32px;
  }

  .vision-padding-lg {
    padding: 48px;
  }

  .vision-padding-xl {
    padding: 64px;
  }

  /* Vision Pro navigation layouts */
  .vision-nav-horizontal {
    @apply flex items-center justify-between;
    min-height: 68px;
  }

  .vision-nav-vertical {
    @apply flex flex-col items-start;
    min-width: 280px;
  }

  /* Vision Pro content sections */
  .vision-section {
    @apply relative;
    padding: 48px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .vision-section-header {
    @apply mb-8;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .vision-section-content {
    @apply space-y-6;
  }

  /* Vision Pro responsive breakpoints for spatial viewing */
  @container (min-width: 640px) {
    .vision-responsive-sm\:grid-cols-2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @container (min-width: 768px) {
    .vision-responsive-md\:grid-cols-3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @container (min-width: 1024px) {
    .vision-responsive-lg\:grid-cols-4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  /* Vision Pro depth shadows */
  .vision-shadow-1 {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.08),
      0 8px 32px rgba(0, 0, 0, 0.04);
  }

  .vision-shadow-2 {
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.12),
      0 16px 48px rgba(0, 0, 0, 0.06);
  }

  .vision-shadow-3 {
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.16),
      0 24px 64px rgba(0, 0, 0, 0.08);
  }

  .vision-shadow-4 {
    box-shadow:
      0 16px 40px rgba(0, 0, 0, 0.2),
      0 32px 80px rgba(0, 0, 0, 0.1);
  }

  /* Vision Pro edge lighting */
  .vision-glow {
    box-shadow:
      0 0 20px rgba(124, 120, 232, 0.3),
      0 0 40px rgba(124, 120, 232, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .vision-glow-secondary {
    box-shadow:
      0 0 20px rgba(76, 215, 246, 0.3),
      0 0 40px rgba(76, 215, 246, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* Vision Pro animation utilities */
  .vision-animate-float {
    animation: vision-float 6s ease-in-out infinite;
  }

  @keyframes vision-float {
    0%,
    100% {
      transform: translateY(0) translateZ(12px);
    }
    50% {
      transform: translateY(-8px) translateZ(20px);
    }
  }

  .vision-animate-pulse-glow {
    animation: vision-pulse-glow 3s ease-in-out infinite;
  }

  @keyframes vision-pulse-glow {
    0%,
    100% {
      box-shadow:
        0 0 20px rgba(124, 120, 232, 0.3),
        0 0 40px rgba(124, 120, 232, 0.2);
    }
    50% {
      box-shadow:
        0 0 30px rgba(124, 120, 232, 0.4),
        0 0 60px rgba(124, 120, 232, 0.3);
    }
  }

  /* Vision Pro reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .vision-animate-float,
    .vision-animate-pulse-glow {
      animation: none;
    }

    .vision-float:hover {
      transform: translateZ(12px);
    }
  }
}

/* ============================================================================
   Focus & accessibility
   ============================================================================ */
:focus-visible {
  outline: 2px solid hsl(var(--ring) / 0.6);
  outline-offset: 2px;
}
:focus:not(:focus-visible) {
  outline: none;
}

/* Transitions */
button,
a,
input,
select,
textarea {
  transition: all 0.15s ease-out;
}

/* Micro-interactions */
.btn-micro {
  transform: translateY(0);
  transition:
    transform 0.15s ease-out,
    box-shadow 0.15s ease-out,
    background-color 0.15s ease-out;
}
.btn-micro:hover {
  transform: translateY(-1px);
}
.btn-micro:active {
  transform: translateY(0);
}

/* Page transitions */
.page-enter {
  opacity: 0;
  transform: translateY(8px);
}
.page-enter-active {
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity 200ms ease-out,
    transform 200ms ease-out;
}
.page-exit {
  opacity: 1;
  transform: translateY(0);
}
.page-exit-active {
  opacity: 0;
  transform: translateY(-8px);
  transition:
    opacity 150ms ease-out,
    transform 150ms ease-out;
}

/* Skeleton shimmer */
@keyframes skeleton-shimmer {
  0% {
    background-position: -200% 0;
  }
  100% {
    background-position: 200% 0;
  }
}
.skeleton-shimmer {
  background: linear-gradient(
    90deg,
    hsl(var(--muted)) 0%,
    hsl(var(--muted-foreground) / 0.1) 50%,
    hsl(var(--muted)) 100%
  );
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

/* GPU-Accelerated Skeleton Shimmer - Performance Optimized */
@keyframes skeleton-shimmer-gpu {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}
.skeleton-shimmer-gpu {
  position: relative;
  overflow: hidden;
  contain: layout style paint;
  transform: translateZ(0);
  will-change: transform;
  backface-visibility: hidden;
}
.skeleton-shimmer-gpu::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    hsl(var(--muted-foreground) / 0.08) 50%,
    transparent 100%
  );
  animation: skeleton-shimmer-gpu 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  transform: translateX(-100%);
}
@supports not (animation-timeline: scroll()) {
  .skeleton-shimmer-gpu::after {
    animation-duration: 1.5s;
  }
}

/* Skeleton Group - CSS Containment */
.skeleton-group {
  contain: layout style;
}
.skeleton-wrapper {
  contain: layout style;
}

/* Fade-in animation for progressive reveal */
@keyframes fade-in {
  from {
    opacity: 0;
    transform: translateY(8px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.animate-fade-in {
  animation: fade-in 300ms ease-out forwards;
}

/* Content transition */
.content-transition {
  transition-property: opacity, transform;
  transition-timing-function: ease-out;
}

/* Skeleton base styles for SkeletonLoader components */
.skeleton-base {
  contain: layout style paint;
  transform: translateZ(0);
}

/* 3D flip card */
.flip-card {
  perspective: 1200px;
}
.flip-card-inner {
  display: grid;
  width: 100%;
  transform-style: preserve-3d;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}
.flip-card.flipped .flip-card-inner {
  transform: rotateY(180deg);
}
.flip-card-front,
.flip-card-back {
  grid-area: 1 / 1;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.flip-card-back {
  transform: rotateY(180deg);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  .flip-card-inner {
    transition: none;
  }
  .skeleton-shimmer {
    animation: none;
  }
  .skeleton-shimmer-gpu {
    animation: none;
  }
  .skeleton-shimmer-gpu::after {
    animation: none;
  }
  .animate-fade-in {
    animation: none;
  }
}

.touch-target {
  min-width: var(--touch-target-min);
  min-height: var(--touch-target-min);
}

.keyboard-nav :focus-visible {
  outline: 2px solid hsl(var(--ring) / 0.6);
  outline-offset: 2px;
  border-radius: 4px;
}

html {
  scroll-behavior: smooth;
}

[data-dialog-focus-trap='true']:focus {
  outline: none;
}

.skeleton-text {
  height: 1em;
  border-radius: 4px;
}
.skeleton-heading {
  height: 1.5em;
  border-radius: 6px;
}
.skeleton-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}
.skeleton-card {
  border-radius: 12px;
  min-height: 200px;
}

/* ============================================================================
   Core Web Vitals - CLS Prevention
   ============================================================================ */

/* Reserve space for images before loading - prevents layout shift */
.aspect-ratio-square {
  aspect-ratio: 1 / 1;
  width: 100%;
}
.aspect-ratio-video {
  aspect-ratio: 16 / 9;
  width: 100%;
}
.aspect-ratio-portrait {
  aspect-ratio: 3 / 4;
  width: 100%;
}
.aspect-ratio-landscape {
  aspect-ratio: 4 / 3;
  width: 100%;
}
.aspect-ratio-icon {
  aspect-ratio: 1 / 1;
  width: 24px;
  height: 24px;
}

/* Fixed dimensions for common elements to prevent CLS */
.dimension-avatar-sm {
  width: 32px;
  height: 32px;
  border-radius: 50%;
}
.dimension-avatar-md {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}
.dimension-avatar-lg {
  width: 48px;
  height: 48px;
  border-radius: 50%;
}
.dimension-avatar-xl {
  width: 64px;
  height: 64px;
  border-radius: 50%;
}

.dimension-icon-sm {
  width: 16px;
  height: 16px;
}
.dimension-icon-md {
  width: 20px;
  height: 20px;
}
.dimension-icon-lg {
  width: 24px;
  height: 24px;
}
.dimension-icon-xl {
  width: 32px;
  height: 32px;
}

/* Typography placeholders - reserve space for text */
.text-placeholder {
  display: block;
  background: hsl(var(--muted));
  border-radius: 4px;
  height: 1em;
}
.text-placeholder-2xl {
  height: 2.5rem;
  max-width: 80%;
}
.text-placeholder-xl {
  height: 2rem;
  max-width: 70%;
}
.text-placeholder-lg {
  height: 1.5rem;
  max-width: 60%;
}
.text-placeholder-md {
  height: 1.25rem;
  max-width: 50%;
}
.text-placeholder-sm {
  height: 1rem;
  max-width: 40%;
}

/* Card skeleton with reserved space */
.card-skeleton {
  background: hsl(var(--muted));
  border-radius: var(--radius);
  min-height: 200px;
  position: relative;
  overflow: hidden;
}
.card-skeleton::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    hsl(var(--muted-foreground) / 0.1) 50%,
    transparent 100%
  );
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
}

/* Loading spinner with fixed dimensions */
.loading-spinner {
  width: 32px;
  height: 32px;
  border: 2px solid hsl(var(--border));
  border-top-color: hsl(var(--primary));
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* Reserve space for dynamic content */
.reserve-space {
  contain: layout;
}

/* Skeleton shimmer animation */
@keyframes skeleton-shimmer {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

/* Font-display swap for web fonts */
@font-face {
  font-family: 'System Fallback';
  font-display: swap;
  src: local(-apple-system), local(BlinkMacSystemFont), local(Segoe UI);
}

/* Prevent CLS from web fonts */
.fonts-loaded {
  font-display: swap;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Min-height reserve for content that loads asynchronously */
.reserve-min-height {
  min-height: 0;
}

/* Prevent CLS from injected banners/modals */
.stable-position {
  position: relative;
  z-index: 0;
}

/* Loading state placeholder */
.placeholder-wave {
  background: linear-gradient(
    90deg,
    hsl(var(--muted)) 0%,
    hsl(var(--muted-foreground) / 0.1) 50%,
    hsl(var(--muted)) 100%
  );
  background-size: 200% 100%;
  animation: placeholder-wave 1.5s ease-in-out infinite;
}

@keyframes placeholder-wave {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}

/* Reserve space for inline SVG icons */
.icon-placeholder {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* Image container with aspect ratio preservation */
.img-container {
  position: relative;
  overflow: hidden;
  background: hsl(var(--muted));
}
.img-container img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.img-container.loaded img {
  opacity: 1;
  transition: opacity 0.3s ease-out;
}
.img-container:not(.loaded) img {
  opacity: 0;
}

/* Defer non-critical content */
.defer-visible {
  content-visibility: auto;
  contain-intrinsic-size: auto 300px;
}

/* Priority loading for above-fold content */
.priority-high {
  fetchpriority: high;
}
.priority-low {
  fetchpriority: low;
}
.priority-normal {
  fetchpriority: normal;
}

/* Reduced CLS from dynamic embeds */
.embed-container {
  position: relative;
  padding-bottom: 56.25%;
  height: 0;
  overflow: hidden;
}
.embed-container iframe,
.embed-container object,
.embed-container embed {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

/* Virtual scroll container stability */
.virtual-scroll-item {
  contain: layout style;
}

/* Animation safety for CLS-sensitive components */
.safe-animation {
  transform: translateZ(0);
  will-change: transform;
}

/* Ensure stable layout for grids */
.grid-stable {
  contain: layout;
}

/* Lazy load boundary for images */
.img-lazy-boundary {
  contain: layout;
  content-visibility: auto;
  contain-intrinsic-size: auto 200px;
}
