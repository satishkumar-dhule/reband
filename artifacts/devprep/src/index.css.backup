  /* Mobile-optimized line heights for better readability */
  .leading-mobile-tight {
    line-height: 1.3;
  }
  .leading-mobile-snug {
    line-height: 1.4;
  }
  .leading-mobile-normal {
    line-height: 1.6;
  }
  .leading-mobile-relaxed {
    line-height: 1.8;
  }
  .leading-mobile-loose {
    line-height: 2;
  }

  /* Mobile-optimized letter spacing */
  .tracking-mobile-tighter {
    letter-spacing: -0.05em;
  }
  .tracking-mobile-tight {
    letter-spacing: -0.025em;
  }
  .tracking-mobile-normal {
    letter-spacing: 0em;
  }
  .tracking-mobile-wide {
    letter-spacing: 0.025em;
  }
  .tracking-mobile-wider {
    letter-spacing: 0.05em;
  }
  .tracking-mobile-widest {
    letter-spacing: 0.1em;
  }

  /* Enhanced responsive spacing system */
  .space-mobile-y > * + * {
    @apply mt-3;
  }
  @media (min-width: 480px) {
    .space-mobile-y > * + * {
      @apply mt-4;
    }
  }
  @media (min-width: 640px) {
    .space-mobile-y > * + * {
      @apply mt-5;
    }
  }
  @media (min-width: 768px) {
    .space-mobile-y > * + * {
      @apply mt-6;
    }
  }
  @media (min-width: 1024px) {
    .space-mobile-y > * + * {
      @apply mt-8;
    }
  }

  .space-mobile-x > * + * {
    @apply ms-3;
  }
  @media (min-width: 480px) {
    .space-mobile-x > * + * {
      @apply ms-4;
    }
  }
  @media (min-width: 640px) {
    .space-mobile-x > * + * {
      @apply ms-5;
    }
  }
  @media (min-width: 768px) {
    .space-mobile-x > * + * {
      @apply ms-6;
    }
  }
  @media (min-width: 1024px) {
    .space-mobile-x > * + * {
      @apply ms-8;
    }
  }

  /* Mobile padding utilities */
