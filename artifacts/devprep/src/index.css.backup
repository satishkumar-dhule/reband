@import 'tailwindcss';
@import 'tw-animate-css';
@import './styles/themes.css';
@import './styles/devprep-ui.css';
@import './styles/tokens.css';
@import './styles/typography.css';
@import './styles/glass.css';
@import './styles/animations.css';
@import './styles/new-animations.css';
@import './styles/layout.css';
@import './styles/responsive.css';
@plugin "@tailwindcss/typography";

@custom-variant dark (&:is(.dark *));

/* ============================================================================
   Tailwind Theme Integration
   Maps design tokens to Tailwind CSS theme
   ============================================================================ */

@theme inline {
  /* Background colors */
  --color-background: var(--color-bg-base);
  --color-foreground: var(--color-fg-base);
  --color-border: var(--color-border-base);
  --color-input: var(--color-border-base);
  --color-ring: var(--color-ring-base);

  /* Card colors */
  --color-card: var(--color-surface-base);
  --color-card-foreground: var(--color-fg-base);
  --color-card-border: var(--color-border-base);

  /* Popover colors */
  --color-popover: var(--color-surface-overlay);
  --color-popover-foreground: var(--color-fg-base);
  --color-popover-border: var(--color-border-base);

  /* Primary colors */
  --color-primary: var(--color-bg-primary);
  --color-primary-foreground: var(--color-fg-inverted);
  --color-primary-border: var(--color-border-primary);

  /* Secondary colors */
  --color-secondary: var(--color-bg-secondary);
  --color-secondary-foreground: var(--color-fg-secondary);
  --color-secondary-border: var(--color-border-secondary);

  /* Muted colors */
  --color-muted: var(--color-bg-muted);
  --color-muted-foreground: var(--color-fg-muted);
  --color-muted-border: var(--color-border-muted);

  /* Accent colors */
  --color-accent: var(--color-bg-accent);
  --color-accent-foreground: var(--color-fg-accent);
  --color-accent-border: var(--color-border-accent);

  /* Destructive colors */
  --color-destructive: var(--color-bg-destructive);
  --color-destructive-foreground: var(--color-fg-inverted);
  --color-destructive-border: var(--color-border-destructive);

  /* Chart colors */
  --color-chart-1: var(--color-bg-primary);
  --color-chart-2: var(--color-bg-success);
  --color-chart-3: var(--color-bg-warning);
  --color-chart-4: var(--glass-accent-primary);
  --color-chart-5: var(--glass-accent-secondary);

  /* Sidebar colors */
  --color-sidebar: var(--color-surface-base);
  --color-sidebar-foreground: var(--color-fg-base);
  --color-sidebar-border: var(--color-border-base);
  --color-sidebar-primary: var(--color-bg-primary);
  --color-sidebar-primary-foreground: var(--color-fg-inverted);
  --color-sidebar-primary-border: var(--color-border-primary);
  --color-sidebar-accent: var(--color-bg-accent);
  --color-sidebar-accent-foreground: var(--color-fg-accent);
  --color-sidebar-accent-border: var(--color-border-accent);
  --color-sidebar-ring: var(--color-ring-base);

  /* Glass theme colors */
  --color-glass-bg: var(--glass-bg-light);
  --color-glass-bg-hover: var(--glass-bg-medium);
  --color-glass-border: var(--glass-border-light);
  --color-glass-border-hover: var(--glass-border-medium);
  --color-luminous-edge: var(--glass-luminous-primary);

  /* Font families */
  --font-sans: var(--font-family-sans);
  --font-headline: var(--font-family-sans);
  --font-serif: var(--font-family-serif);
  --font-mono: var(--font-family-mono);

  /* Border radius */
  --radius-sm: var(--radius-sm);
  --radius-md: var(--radius-md);
  --radius-lg: var(--radius-lg);
  --radius-xl: var(--radius-xl);

  /* Mobile-first design tokens */
  --touch-target-min: 44px;
  --mobile-padding: var(--space-4);
  --mobile-gap: var(--space-3);
  --mobile-font-size-base: var(--font-size-base);
  --mobile-font-size-sm: var(--font-size-sm);
  --mobile-font-size-lg: var(--font-size-lg);
  --mobile-line-height: var(--line-height-normal);
  --mobile-breakpoint-sm: var(--breakpoint-sm);
  --mobile-breakpoint-md: var(--breakpoint-md);
  --mobile-breakpoint-lg: var(--breakpoint-lg);
  --mobile-breakpoint-xl: var(--breakpoint-xl);

  /* Container query breakpoints */
  --container-breakpoint-sm: var(--breakpoint-sm);
  --container-breakpoint-md: var(--breakpoint-md);
  --container-breakpoint-lg: var(--breakpoint-lg);
  --container-breakpoint-xl: var(--breakpoint-xl);
}

/* ============================================================================
   LIGHT MODE — Architect Elite (soft day variant)
   ============================================================================ */
:root {
  /* Apple Vision Pro Glass Theme Tokens */
  --glass-bg: rgba(28, 28, 30, 0.72);
  --glass-bg-hover: rgba(44, 44, 46, 0.8);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-border-hover: rgba(255, 255, 255, 0.2);
  --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  --glass-shadow-hover: 0 12px 40px rgba(0, 0, 0, 0.12);
  --luminous-edge: rgba(124, 120, 232, 0.3);
  --accent-blue: #0a84ff;
  --accent-purple: #bf5af2;
  --accent-teal: #64d2ff;
  --accent-green: #30d158;
  --accent-orange: #ff9f0a;
  --accent-red: #ff453a;
  --text-primary: rgba(255, 255, 255, 0.95);
  --text-secondary: rgba(255, 255, 255, 0.6);
  --text-tertiary: rgba(255, 255, 255, 0.3);
  --bg-gradient: none;

  /* Vision Pro Spatial Glass Variables */
  --glass-vision-primary: rgba(124, 120, 232, 0.15);
  --glass-vision-primary-hover: rgba(124, 120, 232, 0.25);
  --glass-vision-secondary: rgba(76, 215, 246, 0.15);
  --glass-vision-secondary-hover: rgba(76, 215, 246, 0.25);
  --glass-vision-surface: rgba(255, 255, 255, 0.7);
  --glass-vision-surface-hover: rgba(255, 255, 255, 0.8);
  --glass-vision-border: rgba(255, 255, 255, 0.2);
  --glass-vision-border-primary: rgba(124, 120, 232, 0.3);
  --glass-vision-border-secondary: rgba(76, 215, 246, 0.3);
  --glass-vision-shadow-color: rgba(0, 0, 0, 0.08);
  --glass-vision-blur: 20px;
  --glass-vision-blur-light: 12px;
  --glass-vision-blur-heavy: 28px;
  --glass-vision-depth-1: 0px;
  --glass-vision-depth-2: 4px;
  --glass-vision-depth-3: 8px;
  --glass-vision-depth-4: 12px;

  --button-outline: rgba(0, 0, 0, 0.08);
  --badge-outline: rgba(0, 0, 0, 0.04);
  --opaque-button-border-intensity: -6;
  --elevate-1: rgba(0, 0, 0, 0.02);
  --elevate-2: rgba(0, 0, 0, 0.06);

  /* bg: #f4f4f6 */
  --background: 240 10% 96%;
  /* text: #1a1a2e */
  --foreground: 240 33% 14%;
  /* border: very subtle */
  --border: 240 10% 85%;

  /* card: #ffffff */
  --card: 0 0% 100%;
  --card-foreground: 240 33% 14%;
  --card-border: 240 10% 85%;

  --sidebar: 240 10% 96%;
  --sidebar-foreground: 240 33% 14%;
  --sidebar-border: 240 10% 85%;
  --sidebar-primary: 241 100% 72%;
  --sidebar-primary-foreground: 0 0% 100%;
  --sidebar-accent: 240 10% 92%;
  --sidebar-accent-foreground: 240 33% 14%;
  --sidebar-ring: 241 100% 72%;

  --popover: 0 0% 100%;
  --popover-foreground: 240 33% 14%;
  --popover-border: 240 10% 85%;

  /* primary: #7c78e8 — lighter indigo for light mode */
  --primary: 241 100% 72%;
  --primary-foreground: 0 0% 100%;

  /* secondary: surface */
  --secondary: 240 10% 92%;
  --secondary-foreground: 240 33% 14%;

  /* muted: #f0f0f5 */
  --muted: 240 10% 94%;
  --muted-foreground: 240 9% 50%;

  --accent: 240 10% 92%;
  --accent-foreground: 241 100% 72%;

  --destructive: 5 60% 50%;
  --destructive-foreground: 0 0% 100%;

  --input: 240 10% 85%;
  --ring: 241 100% 72%;

  --chart-1: 241 100% 72%;
  --chart-2: 193 89% 50%;
  --chart-3: 218 40% 65%;
  --chart-4: 243 75% 59%;
  --chart-5: 43 96% 56%;

  --app-font-sans:
    -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
  --app-font-headline:
    -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
  --app-font-serif: Georgia, serif;
  --app-font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --radius: 0.5rem;

  --shadow-2xs: 0px 1px 2px 0px rgba(0, 0, 0, 0.04);
  --shadow-xs: 0px 1px 3px 0px rgba(0, 0, 0, 0.06);
  --shadow-sm: 0px 1px 3px 0px rgba(0, 0, 0, 0.07), 0px 1px 2px -1px rgba(0, 0, 0, 0.05);
  --shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.08), 0px 1px 2px -1px rgba(0, 0, 0, 0.06);
  --shadow-md: 0px 4px 6px -1px rgba(0, 0, 0, 0.07), 0px 2px 4px -2px rgba(0, 0, 0, 0.05);
  --shadow-lg: 0px 10px 15px -3px rgba(0, 0, 0, 0.08), 0px 4px 6px -4px rgba(0, 0, 0, 0.05);
  --shadow-xl: 0px 20px 25px -5px rgba(0, 0, 0, 0.08), 0px 8px 10px -6px rgba(0, 0, 0, 0.04);
  --shadow-2xl: 0px 25px 50px -12px rgba(0, 0, 0, 0.12);
  --tracking-normal: 0em;
  --spacing: 0.25rem;

  --sidebar-primary-border: hsl(var(--sidebar-primary));
  --sidebar-accent-border: hsl(var(--sidebar-accent));
  --primary-border: hsl(var(--primary));
  --secondary-border: hsl(var(--secondary));
  --muted-border: hsl(var(--muted));
  --accent-border: hsl(var(--accent));
  --destructive-border: hsl(var(--destructive));
}

/* ============================================================================
   DARK MODE — Apple Vision Pro
   Primary:   #0a84ff  (accent blue)
   Secondary: #bf5af2  (accent purple)
   BG:        #000000 to #1a1a1a gradient
   ============================================================================ */
[data-theme='dark'] {
  /* Apple Vision Pro Glass Theme Tokens */
  --glass-bg: rgba(28, 28, 30, 0.72);
  --glass-bg-hover: rgba(44, 44, 46, 0.8);
  --glass-border: rgba(255, 255, 255, 0.1);
  --glass-border-hover: rgba(255, 255, 255, 0.2);
  --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  --glass-shadow-hover: 0 12px 40px rgba(0, 0, 0, 0.5);
  --luminous-edge: rgba(10, 132, 255, 0.4);
  --accent-blue: #0a84ff;
  --accent-purple: #bf5af2;
  --accent-teal: #64d2ff;
  --accent-green: #30d158;
  --accent-orange: #ff9f0a;
  --accent-red: #ff453a;
  --text-primary: rgba(255, 255, 255, 0.95);
  --text-secondary: rgba(255, 255, 255, 0.6);
  --text-tertiary: rgba(255, 255, 255, 0.3);
  --bg-gradient: linear-gradient(180deg, #000000 0%, #1a1a1a 100%);

  /* Vision Pro Spatial Glass Variables (Dark Mode) */
  --glass-vision-primary: rgba(10, 132, 255, 0.2);
  --glass-vision-primary-hover: rgba(10, 132, 255, 0.3);
  --glass-vision-secondary: rgba(191, 90, 242, 0.2);
  --glass-vision-secondary-hover: rgba(191, 90, 242, 0.3);
  --glass-vision-surface: rgba(28, 28, 30, 0.8);
  --glass-vision-surface-hover: rgba(28, 28, 30, 0.9);
  --glass-vision-border: rgba(255, 255, 255, 0.15);
  --glass-vision-border-primary: rgba(10, 132, 255, 0.4);
  --glass-vision-border-secondary: rgba(191, 90, 242, 0.4);
  --glass-vision-shadow-color: rgba(0, 0, 0, 0.4);
  --glass-vision-blur: 24px;
  --glass-vision-blur-light: 16px;
  --glass-vision-blur-heavy: 32px;
  --glass-vision-depth-1: 0px;
  --glass-vision-depth-2: 6px;
  --glass-vision-depth-3: 12px;
  --glass-vision-depth-4: 18px;

  --button-outline: rgba(10, 132, 255, 0.08);
  --badge-outline: rgba(10, 132, 255, 0.04);
  --opaque-button-border-intensity: 9;
  --elevate-1: rgba(255, 255, 255, 0.03);
  --elevate-2: rgba(255, 255, 255, 0.06);

  /* #000000 */
  --background: 0 0% 0%;
  /* #ffffff */
  --foreground: 0 0% 100%;
  /* #1a1a1a */
  --border: 0 0% 10%;

  /* #1c1c1e */
  --card: 240 3% 11%;
  --card-foreground: 0 0% 100%;
  --card-border: 0 0% 10%;

  /* #000000 */
  --sidebar: 0 0% 0%;
  --sidebar-foreground: 0 0% 100%;
  --sidebar-border: 0 0% 10%;
  /* #0a84ff primary */
  --sidebar-primary: 210 100% 52%;
  --sidebar-primary-foreground: 0 0% 100%;
  /* #1c1c1e */
  --sidebar-accent: 240 3% 11%;
  --sidebar-accent-foreground: 0 0% 100%;
  --sidebar-ring: 210 100% 52%;

  --popover: 240 3% 11%;
  --popover-foreground: 0 0% 100%;
  --popover-border: 0 0% 10%;

  /* primary: #0a84ff */
  --primary: 210 100% 52%;
  --primary-foreground: 0 0% 100%;

  /* secondary surface (#1c1c1e) */
  --secondary: 240 3% 11%;
  --secondary-foreground: 0 0% 100%;

  /* muted: #1c1c1e */
  --muted: 240 3% 11%;
  --muted-foreground: 240 2% 57%;

  /* accent: #1c1c1e */
  --accent: 240 3% 11%;
  --accent-foreground: 210 100% 52%;

  /* destructive: #ff453a */
  --destructive: 2 100% 62%;
  --destructive-foreground: 0 0% 100%;

  --input: 0 0% 10%;
  --ring: 210 100% 52%;

  /* chart-1: #0a84ff primary blue */
  --chart-1: 210 100% 52%;
  /* chart-2: #bf5af2 secondary purple */
  --chart-2: 280 85% 65%;
  /* chart-3: #64d2ff tertiary teal */
  --chart-3: 197 100% 70%;
  /* chart-4: #30d158 green */
  --chart-4: 143 100% 56%;
  /* chart-5: #ff9f0a amber */
  --chart-5: 36 100% 50%;

  --app-font-sans:
    -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
  --app-font-headline:
    -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', system-ui, sans-serif;
  --app-font-serif: Georgia, serif;
  --app-font-mono: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --radius: 0.5rem;

  --shadow-2xs: 0px 1px 2px 0px rgba(0, 0, 0, 0.5);
  --shadow-xs: 0px 1px 3px 0px rgba(0, 0, 0, 0.6);
  --shadow-sm: 0px 1px 3px 0px rgba(0, 0, 0, 0.6), 0px 1px 2px -1px rgba(0, 0, 0, 0.5);
  --shadow: 0px 2px 4px 0px rgba(0, 0, 0, 0.7), 0px 1px 2px -1px rgba(0, 0, 0, 0.5);
  --shadow-md: 0px 4px 6px -1px rgba(0, 0, 0, 0.7), 0px 2px 4px -2px rgba(0, 0, 0, 0.5);
  --shadow-lg: 0px 10px 15px -3px rgba(0, 0, 0, 0.8), 0px 4px 6px -4px rgba(0, 0, 0, 0.5);
  --shadow-xl: 0px 20px 25px -5px rgba(0, 0, 0, 0.8), 0px 8px 10px -6px rgba(0, 0, 0, 0.5);
  --shadow-2xl: 0px 25px 50px -12px rgba(0, 0, 0, 0.9);

  --sidebar-primary-border: hsl(var(--sidebar-primary));
  --sidebar-accent-border: hsl(var(--sidebar-accent));
  --primary-border: hsl(var(--primary));
  --secondary-border: hsl(var(--secondary));
  --muted-border: hsl(var(--muted));
  --accent-border: hsl(var(--accent));
  --destructive-border: hsl(var(--destructive));
}

@layer base {
  * {
    @apply border-border;
  }
  html {
    height: 100%;
  }
  body {
    @apply font-sans antialiased bg-background text-foreground;
    margin: 0;
    height: 100%;
    overflow: hidden;
  }
  [data-theme='dark'] body {
    background: var(--bg-gradient);
  }
}

/* Scrollbar — minimal Architect Elite style */
::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: hsl(var(--border));
  border-radius: 99px;
}
::-webkit-scrollbar-thumb:hover {
  background: hsl(var(--primary) / 0.4);
}

/* Sidebar hidden on mobile - handled in devprep-ui.css */
.sidebar {
  display: flex;
}

/* Apple Vision Pro Glass Utilities */
@utility glass {
  @apply bg-glass-bg backdrop-blur-lg border-glass-border;
  box-shadow: var(--glass-shadow);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  &:hover {
    @apply bg-glass-bg-hover border-glass-border-hover;
    box-shadow: var(--glass-shadow-hover);
  }
}

@layer utilities {
  input[type='search']::-webkit-search-cancel-button {
    @apply hidden;
  }

  .font-headline {
    font-family: var(--app-font-headline);
  }

  .no-default-hover-elevate {
  }
  .no-default-active-elevate {
  }

  .toggle-elevate::before,
  .toggle-elevate-2::before {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0px;
    border-radius: inherit;
    z-index: -1;
  }
  .toggle-elevate.toggle-elevated::before {
    background-color: var(--elevate-2);
  }
  .border.toggle-elevate::before {
    inset: -1px;
  }

  .hover-elevate:not(.no-default-hover-elevate),
  .active-elevate:not(.no-default-active-elevate),
  .hover-elevate-2:not(.no-default-hover-elevate),
  .active-elevate-2:not(.no-default-active-elevate) {
    position: relative;
    z-index: 0;
  }

  .hover-elevate:not(.no-default-hover-elevate)::after,
  .active-elevate:not(.no-default-active-elevate)::after,
  .hover-elevate-2:not(.no-default-hover-elevate)::after,
  .active-elevate-2:not(.no-default-active-elevate)::after {
    content: '';
    pointer-events: none;
    position: absolute;
    inset: 0px;
    border-radius: inherit;
    z-index: 999;
  }
  .hover-elevate:hover:not(.no-default-hover-elevate)::after,
  .active-elevate:active:not(.no-default-active-elevate)::after {
    background-color: var(--elevate-1);
  }
  .hover-elevate-2:hover:not(.no-default-hover-elevate)::after,
  .active-elevate-2:active:not(.no-default-active-elevate)::after {
    background-color: var(--elevate-2);
  }
  .border.hover-elevate:not(.no-hover-interaction-elevate)::after,
  .border.active-elevate:not(.no-active-interaction-elevate)::after,
  .border.hover-elevate-2:not(.no-hover-interaction-elevate)::after,
  .border.active-elevate-2:not(.no-active-interaction-elevate)::after {
    inset: -1px;
  }

  @media (min-width: 640px) {
    .container-mobile {
      @apply px-6;
    }
  }
  @media (min-width: 768px) {
    .container-mobile {
      @apply px-8;
    }
  }
  @media (min-width: 1024px) {
    .container-mobile {
      @apply px-10;
    }
  }

  /* Mobile-first grid utilities */
  .grid-mobile-1 {
    @apply grid grid-cols-1 gap-4;
  }
  .grid-mobile-2 {
    @apply grid grid-cols-1 gap-4;
  }
  @media (min-width: 640px) {
    .grid-mobile-2 {
      @apply grid-cols-2 gap-6;
    }
  }
  .grid-mobile-3 {
    @apply grid grid-cols-1 gap-4;
  }
  @media (min-width: 640px) {
    .grid-mobile-3 {
      @apply grid-cols-2 gap-6;
    }
  }
  @media (min-width: 768px) {
    .grid-mobile-3 {
      @apply grid-cols-3 gap-8;
    }
  }
  .grid-auto-fit {
    @apply grid gap-4;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  /* Mobile-first flex utilities */
  .flex-mobile-col {
    @apply flex flex-col gap-4;
  }
  @media (min-width: 640px) {
    .flex-mobile-col {
      @apply flex-row gap-6;
    }
  }
  .flex-mobile-wrap {
    @apply flex flex-wrap gap-2;
  }
  @media (min-width: 640px) {
    .flex-mobile-wrap {
      @apply gap-4;
    }
  }

  /* Touch-friendly button utilities */
  .btn-touch {
    @apply min-h-[44px] min-w-[44px] px-4 py-3 text-base font-medium rounded-lg;
    @apply active:scale-95 transition-transform duration-150;
    -webkit-tap-highlight-color: transparent;
  }
  .btn-touch-sm {
    @apply min-h-[44px] min-w-[44px] px-3 py-2 text-sm font-medium rounded-md;
    @apply active:scale-95 transition-transform duration-150;
    -webkit-tap-highlight-color: transparent;
  }
  .btn-touch-lg {
    @apply min-h-[48px] min-w-[48px] px-6 py-3 text-lg font-semibold rounded-xl;
    @apply active:scale-95 transition-transform duration-150;
    -webkit-tap-highlight-color: transparent;
  }

  /* Mobile navigation utilities */
  .nav-mobile {
    @apply fixed bottom-0 left-0 right-0 z-50;
    @apply bg-background/95 backdrop-blur-md border-t border-border;
    @apply flex justify-around items-center h-16;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  @media (min-width: 768px) {
    .nav-mobile {
      @apply static h-auto border-t-0 border-b;
    }
  }
  .nav-item {
    @apply min-h-[44px] min-w-[44px] px-3 py-2 text-sm font-medium rounded-md;
    @apply active:scale-95 transition-transform duration-150;
    @apply flex flex-col items-center justify-center gap-1;
    @apply text-muted-foreground hover:text-foreground;
    -webkit-tap-highlight-color: transparent;
  }
  .nav-item.active {
    @apply text-primary;
  }

  /* Mobile spacing utilities */
  .space-mobile-y > * + * {
    @apply mt-4;
  }
  @media (min-width: 640px) {
    .space-mobile-y > * + * {
      @apply mt-6;
    }
  }
  @media (min-width: 768px) {
    .space-mobile-y > * + * {
      @apply mt-8;
    }
  }

  /* Mobile-first typography scale with fluid values */
  /* Base: 16px on mobile, scaling to 18px on desktop */
  .text-mobile-xs {
    @apply text-[0.75rem] leading-[1.4];
