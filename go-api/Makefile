.PHONY: all build run test lint clean build-worker dist

BINARY     := bin/devprep-api
WASM_OUT   := dist/app.wasm
WORKER_JS  := dist/_worker.js
GO         := go
GOOS_WASM  := js
GOARCH_WASM:= wasm

# ─── Default: build + run ─────────────────────────────────────────────────────
all: build

# ─── Local server binary ──────────────────────────────────────────────────────
build:
	@echo "› Building server binary…"
	$(GO) build -trimpath -ldflags="-s -w" -o $(BINARY) .
	@echo "✓ $(BINARY)"

run: build
	@echo "› Starting server on :$${GO_API_PORT:-3001}…"
	./$(BINARY)

# ─── Tests ────────────────────────────────────────────────────────────────────
test:
	$(GO) test -race -timeout 60s ./...

# ─── Lint (requires golangci-lint) ────────────────────────────────────────────
lint:
	golangci-lint run ./...

# ─── Cloudflare Workers (WASM) build ─────────────────────────────────────────
# Produces dist/app.wasm + dist/_worker.js (the JS glue loaded by wrangler).
build-worker: dist
	@echo "› Building WASM worker…"
	GOOS=$(GOOS_WASM) GOARCH=$(GOARCH_WASM) \
		$(GO) build -tags worker -trimpath \
		-ldflags="-s -w" \
		-o $(WASM_OUT) ./worker/
	@echo "› Copying wasm_exec.js…"
	cp "$$($(GO) env GOROOT)/misc/wasm/wasm_exec.js" dist/
	@echo "› Generating _worker.js glue…"
	@printf '%s\n' \
		'// Auto-generated by make build-worker — do not edit.' \
		'import { createWorker } from "@syumai/workers/cloudflare";' \
		'import app from "./app.wasm";' \
		'export default createWorker(app);' \
		> $(WORKER_JS)
	@echo "✓ $(WASM_OUT)  $(WORKER_JS)"

dist:
	@mkdir -p dist

# ─── Clean ────────────────────────────────────────────────────────────────────
clean:
	rm -rf bin/ dist/

# ─── Module tidy ──────────────────────────────────────────────────────────────
tidy:
	$(GO) mod tidy
