modules = ["nodejs-20", "python-3.11", "python-3.12", "web"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[[artifacts]]
id = "artifacts/devprep"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/mockup-sandbox: Component Preview Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Kiro IDE (VNC)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5173 BASE_PATH=/__mockup/ pnpm --filter @workspace/mockup-sandbox run dev"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "webview"
isCanvasWorkflow = true

[[workflows.workflow]]
name = "Kiro IDE (VNC)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start-kiro.sh"

[workflows.workflow.metadata]
outputType = "vnc"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["glib", "nss", "nspr", "atk", "cups", "dbus", "libdrm", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "libgbm", "libxkbcommon", "pango", "cairo", "alsa-lib", "gh", "chromium", "chromium-xorg-conf", "firefox", "firefox-esr", "act", "containerd", "vim-full", "ollama", "gotrue-supabase", "plan9port", "tmux", "zip"]

[[ports]]
localPort = 3001
externalPort = 6000

[[ports]]
localPort = 3128
externalPort = 3002
exposeLocalhost = true

[[ports]]
localPort = 4096
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 8000

[[ports]]
localPort = 5001
externalPort = 8081

[[ports]]
localPort = 5002
externalPort = 9000

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 8080

[[ports]]
localPort = 5175

[[ports]]
localPort = 5176

[[ports]]
localPort = 5177

[[ports]]
localPort = 6080
externalPort = 8008

[[ports]]
localPort = 6800
externalPort = 6800

[[ports]]
localPort = 9999
externalPort = 8099

[[ports]]
localPort = 63774
externalPort = 3001
exposeLocalhost = true

