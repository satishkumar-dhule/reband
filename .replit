ANTHROPIC_BASE_URL = "http://localhost:4000"
ANTHROPIC_API_KEY = "_DUMMY_API_KEY_"
LITELLM_MASTER_KEY = "sk-local-dev-key"
OPENAI_API_KEY = "_DUMMY_API_KEY_"

